# OpenJCK Cloud — Environment Configuration
# Copy this file to the appropriate location and fill in values.
#
# Files to create:
# - .env (backend, in server/ directory)
# - .env.local (dashboard, in dashboard/ directory)
# - .env (Python SDK, in project root or user environment)
#
# DO NOT commit any .env files to version control.

# ============================================================================
# Python SDK (openjck package)
# ============================================================================
# Provider selection: anthropic (default), openai, groq, together, custom
OPENJCK_LLM_PROVIDER=anthropic

# Anthropic API key (also supports legacy ANTHROPIC_API_KEY)
OPENJCK_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible API key (OpenAI, Groq, Together, DeepSeek, etc.)
# Also supports legacy OPENAI_API_KEY
OPENJCK_OPENAI_API_KEY=sk-...

# OpenAI-compatible base URL (optional; defaults per provider)
# Groq: https://api.groq.com/openai/v1
# Together: https://api.together.xyz/v1
# OpenAI: https://api.openai.com/v1
OPENJCK_OPENAI_BASE_URL=

# Custom pricing overrides as JSON string (optional)
# Example: {"anthropic:claude-opus-4": {"input_per_million": 15.00, "output_per_million": 75.00}}
OPENJCK_PRICING_JSON=

# ============================================================================
# Backend Server (Node.js/Express on Render)
# ============================================================================
# Place this section in `server/.env` (not committed to git)

# Supabase admin connection (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Server port (default: 7070)
PORT=7070

# Anthropic API key — OpenJCK's hosted key (used when org has no BYOK key)
# This is OpenJCK's own Anthropic account key for AI Fix feature
ANTHROPIC_API_KEY=sk-ant-[openjck-hosted-key]

# 32-byte hex string for AES-256-GCM encryption of org AI keys (BYOK)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=64_hex_char_string_here

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================================================
# Dashboard (Next.js on Vercel)
# ============================================================================
# Place these in Vercel Environment Variables or `dashboard/.env.local`

# Supabase connection (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Backend API URL (default: http://localhost:7070 for local dev)
# For production, set to your Render URL: https://openjck-api.onrender.com
NEXT_PUBLIC_OPENJCK_API_URL=http://localhost:7070

# ============================================================================
# Optional: External Services
# ============================================================================
# Sentry DSN for error tracking (if using Sentry)
# SENTRY_DSN=https://...

# Cloudflare (if using for DNS/WAF, optional)
# CLOUDFLARE_API_TOKEN=...

# ============================================================================
# Notes
# ============================================================================
# 1. Production values will differ from local development.
# 2. Render/Vercel allow you to set environment variables in their dashboard.
# 3. Never commit .env files. They are already in .gitignore.
# 4. After filling values, test locally:
#    - Backend: cd server && npm run dev
#    - Dashboard: cd dashboard && npm run dev
#    - Python SDK: pip install -e .[dev] && python -m openjck.test